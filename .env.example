# --- Required (both modes) ---
ZENDESK_SUBDOMAIN=xxx

# --- API-token mode (legacy) ---
ZENDESK_EMAIL=xxx
ZENDESK_API_KEY=xxx

# --- OAuth mode ---
# If ZENDESK_CLIENT_ID is set, the server runs in OAuth mode and reads tokens
# from ~/.config/zendesk-mcp/{subdomain}.json (written by `zendesk-auth`).
# In OAuth mode, ZENDESK_EMAIL and ZENDESK_API_KEY are ignored.
# ZENDESK_CLIENT_ID=xxx
# ZENDESK_CLIENT_SECRET=xxx

# --- Transport ---
# stdio (default) — spawned by Claude Code via command config
# http            — HTTP server; configure Claude Code with url: http://127.0.0.1:8000/mcp
# ZENDESK_MCP_TRANSPORT=stdio
# ZENDESK_MCP_PORT=8000
